 {
  "compilerOptions": {
    "target": "es2024",
    "strict": true,
    "preserveConstEnums": true,
    "noEmit": true,
    "sourceMap": false,
    "module":"commonjs",
    "moduleResolution":"node",
    "esModuleInterop": true, 
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true, 
    "isolatedModules": true,
    "types": ["node"]
  },
  "exclude": ["node_modules", "**/*.test.ts"]
}