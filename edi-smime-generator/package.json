  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "build": "rimraf build && esbuild src/lambda.ts --bundle --platform=node --target=node22 --sourcemap=inline --minify --outfile=build/lambda.js",
    "dist": "cd build && bestzip lambda.zip *.js && rimraf ../dist && shx mkdir ../dist && mv lambda.zip ../dist",
    "dist:generator": "bun build src/generator.ts --bundle --target=bun --sourcemap=linked --minify --outdir=dist-generator --outfile=edi-generator.js",
    "test": "echo \"Error: no test specified\""
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.57.4",
    "@types/aws-lambda": "^8.10.161",
    "@types/node": "^22.19.15",
    "bestzip": "^2.2.1",
    "esbuild": "^0.27.3",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@aws-lambda-powertools/logger": "^2.31.0",
    "@aws-sdk/client-s3": "^3.1005.0",
    "@js-joda/core": "^5.7.0",
    "@js-joda/timezone": "^2.23.0"
  }
